---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import me from "../assets/me.jpg";
import HomeProjectCard from "../components/HomeProjectCard.astro";
import myblog from "../assets/myblog.png";
import icongenerator from "../assets/icon-generator-project.png";
import AboutPage from "../components/AboutPage.astro";
---

<Layout title="Brian Stricker - Portfolio">
 <main>
  <div class="main container">
   <div class="row">
    <div style="margin-top:2px;">
     <div class="text">
      <span style="font-size: 1.2rem">Hello, I'm</span>
      <h1 class="name">Brian Stricker</h1>
      <p style="font-size: 1.6rem; margin-top: .5rem">
       I'm a Full Stack Developer.
      </p>
      <div style="margin-top: 1rem; display: flex; flex-direction: column;">
       <p style="margin-bottom: 1rem;">Check out one of my projects:</p>
      </div>
     </div>
     <div class="cards">
      <HomeProjectCard
       title="Fullstack Blog"
       link="https://blog.brianstricker.com/"
       image={myblog}
      />
      <HomeProjectCard
       title="Icon Generator"
       link="https://icons.brianstricker.com/"
       image={icongenerator}
      />
     </div>
    </div>
    <div>
     <Image src={me} alt="Brian Stricker" class="profileImage" format="webp" />
    </div>
   </div>
  </div>
 </main>
 <AboutPage />
</Layout>

<style>
 .main {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
 }
 .row {
  display: flex;
  flex-direction: row;
  gap: 4rem;
  padding: 1rem 1rem;
  width: 100%;
  justify-content: space-between;
  position: relative;
  bottom: -5rem;
  @media screen and (max-width: 900px) {
   display: block;
   bottom: 1rem;
  }
 }
 .name {
  font-size: 6rem;
  font-weight: 700;
  line-height: 1;
  @media screen and (max-width: 900px) {
   font-size: 4rem;
  }
  @media screen and (max-width: 700px) {
   font-size: 3rem;
  }
 }
 .profileImage {
  object-fit: contain;
  width: 400px;
  height: fit-content;
  @media screen and (max-width: 900px) {
   display: none;
  }
 }
 .cards {
  display: flex;
  column-gap: 1rem;
  row-gap: 0.5rem;
  @media screen and (max-width: 700px) {
   flex-direction: column;
  }
 }
 .text {
  margin: 0 auto;
  @media screen and (max-width: 550px) {
   max-width: 95%;
  }
 }
</style>
