---
import ArrowDown from "./ArrowDown.astro";
---

<main>
 <div class="main">
  <div class="container">
   <h2>About</h2>
   <div class="content">
    My name is Brian Stricker, and I'm an aspiring fullstack developer. I
    primarily use the MERN stack but I've dabbled with other frameworks and
    languages.
   </div>
  </div>
 </div>
 <div class="skillButton">
  <span class="skills">skills</span><ArrowDown />
 </div>
</main>

<style>
 .main {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 93vh;
  width: 100%;
 }
 h2 {
  font-size: 3rem;
  text-align: center;
  position: relative;
  top: -3rem;
 }
 .content {
  max-width: 600px;
 }
 .skillButton {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  top: -0.1rem;
  gap: 8px;
  cursor: pointer;
  padding: 0.5rem 1rem;
  box-shadow: inset 0 0 0 0 #2196f3;
  transition: all 0.5s ease-in-out;
  width: fit-content;
  margin: 0 auto;
  &:hover {
   transform: scale(1.1);
   box-shadow: inset 400px 0 0 0 #2196f3;
  }
 }
 .skills {
  font-size: 1.5rem;
 }
</style>
