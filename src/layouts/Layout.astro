---
import "@fontsource/indie-flower";
import "@fontsource/poppins";
import Header from "../components/Header.astro";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
 <head>
  <meta charset="UTF-8" />
  <meta name="description" content="Portfolio website made by Brian Stricker" />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
 </head>
 <body>
  <Header />
  <slot />
 </body>
</html>
<style is:global>
 html,
 body {
  font-family: "Poppins", sans-serif;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
 }
 html.dark {
  background-color: #1f2023;
  color: #dadada;
 }
 main {
  min-height: 100vh;
  width: 100%;
 }
 .fancy {
  font-family: "Indie Flower", cursive;
 }
 .container {
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 2rem;
 }
 a {
  text-decoration: none;
  color: inherit;
 }
 ul,
 ol {
  list-style: none;
 }
 h1,
 h2,
 h3,
 h4,
 h5,
 h6,
 p {
  margin: 0;
  padding: 0;
  line-height: 1.3;
 }
</style>
